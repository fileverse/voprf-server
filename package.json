{
  "name": "voprf-server",
  "version": "1.0.0",
  "description": "VOPRF Server implementation in TypeScript",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "NODE_ENV=production node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "clean": "rm -rf dist",
    "postinstall": "npm run build"
  },
  "keywords": [
    "voprf",
    "server",
    "typescript",
    "express",
    "nodejs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@cloudflare/voprf-ts": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "js-base64": "^3.7.7",
    "mongoose": "^6.5.4",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "@types/bunyan": "^1.8.11",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/express-fileupload": "^1.5.1",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.21",
    "@types/request": "^2.48.12",
    "@types/uuid": "^10.0.0",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.2",
    "typescript": "^5.0.4"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}
