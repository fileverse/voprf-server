# --- Semaphore gate (docs/gate-server-design.md §9) ---
# NETWORK=sepolia                # sepolia | gnosis — the ONE chain this gate serves
# RPC_URL=https://ethereum-sepolia-rpc.publicnode.com   # endpoint for NETWORK
# MONGO_URI=mongodb://127.0.0.1:27017/fileverse-gate
# GATE_MASTER_KEY=<base64 32 bytes — scripts/generate-gate-master-key.ts>
# PRIVY_APP_ID=
# PRIVY_APP_SECRET=              # from the Privy dashboard; @privy-io/node verifies id-tokens via the app JWKS
# GATE_DEV_OWNER_DID_OVERRIDE=   # dev/harness ONLY — boot-refused when NODE_ENV=production (ensure your deploy actually sets NODE_ENV=production; npm start does)
